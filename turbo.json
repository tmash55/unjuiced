{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "PLAN_COOKIE_SECRET",
    "SUPABASE_SERVICE_ROLE_KEY",
    "STRIPE_PUBLIC_KEY",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "DUB_API_KEY",
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "NEXT_PUBLIC_WEBSITE_URL",
    "NEXT_PUBLIC_SITE_URL",
    "NEXT_PUBLIC_STRIPE_SCOUT_MONTHLY",
    "NEXT_PUBLIC_STRIPE_SCOUT_YEARLY",
    "NEXT_PUBLIC_STRIPE_SHARP_MONTHLY",
    "NEXT_PUBLIC_STRIPE_SHARP_YEARLY",
    "NEXT_PUBLIC_STRIPE_EDGE_MONTHLY",
    "NEXT_PUBLIC_STRIPE_EDGE_YEARLY",
    "UPSTASH_REDIS_REST_URL",
    "UPSTASH_REDIS_REST_TOKEN",
    "BREVO_API_KEY",
    "BREVO_BASE_URL",
    "BREVO_SYSTEM_LIST_ID",
    "CUSTOMERIO_SITE_ID",
    "CUSTOMERIO_API_KEY",
    "BEEHIIV_API_KEY",
    "BEEHIIV_PUBLICATION_ID",
    "RESEND_API_KEY",
    "ODDSBLAZE_API_KEY",
    "CUSTOMERIO_APP_API_KEY",
    "CRON_SECRET",
    "UPSTASH_REDIS_PUBSUB_URL",
    "UPSTASH_REDIS_PUBSUB_TOKEN",
    "UPSTASH_REDIS_COMMAND_URL",
    "UPSTASH_REDIS_COMMAND_TOKEN",
    "EXPO_PUBLIC_SUPABASE_URL",
    "EXPO_PUBLIC_SUPABASE_KEY",
    "test"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", "build/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    }
  }
}
